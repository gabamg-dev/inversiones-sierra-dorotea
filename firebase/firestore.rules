rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isProjectMember() {
      return isSignedIn()
        && exists(/databases/$(database)/documents/projectMembers/$(request.auth.uid))
        && get(/databases/$(database)/documents/projectMembers/$(request.auth.uid)).data.active == true;
    }

    // projectMembers/{uid}
    match /projectMembers/{uid} {
      // Lectura: solo miembros activos del proyecto.
      allow read: if isProjectMember();

      // Escritura: por ahora restringida al propio documento del usuario autenticado.
      // En fases posteriores, el alta de miembros puede moverse a Cloud Functions / Admin SDK.
      allow create, update, delete: if isSignedIn()
        && request.auth.uid == uid
        && isProjectMember();
    }

    // users/{uid} — perfil de app (no confundir con auth.users)
    match /users/{uid} {
      allow read: if isProjectMember();
      allow create, update, delete: if isSignedIn()
        && request.auth.uid == uid
        && isProjectMember();
    }

    // movements/{movementId}
    match /movements/{movementId} {
      allow read: if isProjectMember();
      allow create, update, delete: if isProjectMember();
    }

    // auditLogs/{logId}
    // Nota: idealmente la escritura será server-side; por ahora se permite a miembros activos.
    match /auditLogs/{logId} {
      allow read: if isProjectMember();
      allow create, update, delete: if isProjectMember();
    }

    // attachments/{attachmentId}
    match /attachments/{attachmentId} {
      allow read: if isProjectMember();
      allow create, update, delete: if isProjectMember();
    }
  }
}
