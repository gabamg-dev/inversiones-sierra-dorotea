rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isProjectMember() {
      return isSignedIn()
        && exists(/databases/$(database)/documents/projectMembers/$(request.auth.uid))
        && get(/databases/$(database)/documents/projectMembers/$(request.auth.uid)).data.active == true;
    }

    // projectMembers/{uid}
    match /projectMembers/{uid} {
      // Cada usuario puede leer su propio documento (bootstrap / verificación sin dependencia circular).
      allow read: if isSignedIn() && request.auth.uid == uid;

      // Bootstrap: permitir que un usuario autenticado cree su propio `projectMembers/{uid}`
      // solo si el documento aún no existe (primer login / alta inicial).
      allow create: if isSignedIn()
        && request.auth.uid == uid
        && !exists(/databases/$(database)/documents/projectMembers/$(uid))
        && request.resource.data.uid == uid
        && request.resource.data.active == true;

      // Actualización/borrado: solo miembros activos (endurecer luego con roles admin).
      allow update, delete: if isSignedIn()
        && request.auth.uid == uid
        && isProjectMember();
    }

    // users/{uid} — perfil de app (no confundir con auth.users)
    match /users/{uid} {
      allow read: if isProjectMember();
      allow create, update, delete: if isSignedIn()
        && request.auth.uid == uid
        && isProjectMember();
    }

    // movements/{movementId}
    match /movements/{movementId} {
      allow read: if isProjectMember();
      allow create, update, delete: if isProjectMember();
    }

    // auditLogs/{logId}
    // Nota: idealmente la escritura será server-side; por ahora se permite a miembros activos.
    match /auditLogs/{logId} {
      allow read: if isProjectMember();
      allow create, update, delete: if isProjectMember();
    }

    // attachments/{attachmentId}
    match /attachments/{attachmentId} {
      allow read: if isProjectMember();
      allow create, update, delete: if isProjectMember();
    }
  }
}
