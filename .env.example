# Variables públicas (se pueden exponer al cliente)
# - NEXT_PUBLIC_* puede ir al frontend (por diseño)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Variables privadas (NUNCA exponer en frontend)
# - Solo en servidor (Vercel Environment Variables / server-side)
SUPABASE_SERVICE_ROLE_KEY=

# Capa 1 (opcional): clave general de acceso al sitio
SITE_ACCESS_PASSWORD=

# IA (futuro): endpoint server-side /api/ai-assistant
AI_PROVIDER= # openai | gemini
AI_MODEL=
OPENAI_API_KEY=
GEMINI_API_KEY=

